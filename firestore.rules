rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'admin';
    }

    // Admin collection
    match /admins/{uid} {
      allow read: if isAuth() && request.auth.uid == uid;
      allow write: if isAdmin();
    }

    // Public read, admin write
    match /projects/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /news/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /events/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /gallery/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /galleryItems/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Volunteers — public can query (for duplicate check) and create.
    // Only specific fields are needed for duplicate check queries.
    // Admin can do full read/update/delete.
    match /volunteers/{id} {
      allow create: if true;
      allow read:   if true;   // needed for duplicate ID/phone/email check
      allow update, delete: if isAdmin();
    }

    // Contact messages — public create only, admin manages
    match /contactMessages/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Newsletter — public create only, admin manages
    match /newsletterSubscribers/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

  }
}