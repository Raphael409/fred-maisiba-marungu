rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/admins/$(request.auth.uid)).data.role == 'admin';
    }

    // Admin collection
    match /admins/{uid} {
      allow read: if isAuth() && request.auth.uid == uid;
      allow write: if isAdmin();
    }

    // Public read collections
    match /projects/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /news/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /events/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /galleryItems/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /gallery/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Public submit collections
    match /contactMessages/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /volunteers/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /newsletterSubscribers/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

  }
}